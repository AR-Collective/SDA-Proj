@startuml
top to bottom direction
skinparam backgroundColor #F9FAFB
skinparam shadowing false
skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #1F2937
    ArrowColor #374151
    FontName "Segoe UI"
}

title SDA Phase 3 - Sensor Pipeline Architecture

' ENTRY POINT
package "main.py" {
    class Pipeline {
        input_producer
        core
        telemetry_proc
        agg_process
        gui_process
        --
        bootstrap()
        validate_config()
        init_queues()
        run_input()
        run_core()
        run_agregate()
        run_telemetry()
        run_output()
    }

    class Observer_Telemetry {
        update(data)
    }
}

' INPUT LAYER
package "plugins/inputs" {
    class GenericInputProducer {
        queue
        schema_mapping
        input_delay
        schema_mapper
        --
        run(dataset_path)
    }

    class SchemaMapper {
        schema_mapping
        --
        map_row(row)
    }

    class InputValidator {
        config
        --
        validate_all()
    }
}

' CORE LAYER
package "core" {
    class CoreManager {
        workers
        input_queue
        agg_queue
        processes_arr
        --
        initialize_multiprocessing()
        generate_worker()
        shutdown_core()
    }

    class CoreLogic {
        input_queue
        output_queue
        config
        --
        process()
        _validate(packet)
    }

    class Agregator {
        queue
        output_queue
        pq
        deque
        expected_id
        --
        agregate()
        _generate_output(packet)
    }

    interface Observer {
        update(data)
    }

    class Telemetry {
        input_queue
        agregate_queue
        output_queue
        observers
        stop_event
        --
        subscribe(observer)
        notify()
        poll(interval)
        quit()
    }
}

' STREAMLIT GUI / OUTPUT LAYER
package "plugins/outputs" {
    class StreamlitApp {
        socket
        data_list
        timestamps
        pipeline_process
        --
        load_config()
        save_config(config)
        start_pipeline()
        stop_pipeline()
        listen_on_udp()
        render_charts()
        render_statistics()
    }
}

' CONFIGURATION
package "config.json" {
    class Config {
        schema_mapping
        pipeline_dynamics
        processing
        dataset_path
    }
}

' ORCHESTRATION
Pipeline --> GenericInputProducer
Pipeline --> CoreManager
Pipeline --> Agregator
Pipeline --> Telemetry
Pipeline --> StreamlitApp
Pipeline --> InputValidator
Pipeline --> Config

' INPUT CHAIN
GenericInputProducer --> SchemaMapper
GenericInputProducer --> Config

' CORE CHAIN
CoreManager --> CoreLogic
CoreLogic --> Config
Telemetry --> Observer
Observer_Telemetry ..|> Observer

' AGREGATION
Agregator --> Config

' DATA FLOW
GenericInputProducer --> CoreLogic : Queue1 (Input)
CoreLogic --> Agregator : Queue2 (Aggregate)
Agregator --> StreamlitApp : UDP (Output)

' MONITORING
Telemetry ..> CoreLogic : monitors input queue
Telemetry ..> Agregator : monitors agregate & output queues

' GUI CONTROL
StreamlitApp ..> Pipeline : control

note right of Pipeline
  Orchestrates all processes
  Manages graceful shutdown
end note

note right of CoreLogic
  PBKDF2 HMAC SHA-256
  Signature validation
  ~1-2 packets pass
end note

note right of Agregator
  Priority queue ordering
  Running average window
  Out-of-order handling
end note

note right of StreamlitApp
  Dark dashboard UI
  4 chart types
  9 real-time metrics
  Config management
  Process control
end note
@enduml
