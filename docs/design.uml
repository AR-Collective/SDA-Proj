@startuml

' =========================
' Layout & Global Styling
' =========================
left to right direction
skinparam backgroundColor #F9FAFB
skinparam shadowing false
skinparam classAttributeIconSize 0

skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #1F2937
    ArrowColor #374151
    FontName Segoe UI
    FontSize 12
}

skinparam package {
    BackgroundColor #E5E7EB
    BorderColor #374151
}

skinparam stereotypeCBackgroundColor #DBEAFE
skinparam stereotypeCBorderColor #1D4ED8

title GDP Analysis Tool - Layered Plugin Architecture

' =========================
' Application Layer
' =========================
package "Application Layer" {

    class Main <<EntryPoint>> {
        + bootstrap()
        + loadConfig()
    }
}

' =========================
' Core Layer
' =========================
package "Core" {

    interface DataSource <<PipelineService>> {
        + read(filepath: str)
    }

    interface DataSink <<PipelineService>> {
        + write(records, config)
    }

    class Engine <<Core>> {
        + execute(data, config)
    }

    class CleanerEngine <<Core>>
    class FilterEngine <<Core>>
    class MeltingEngine <<Core>>

    Engine --> CleanerEngine
    Engine --> FilterEngine
    Engine --> MeltingEngine
}

' =========================
' Input Plugins
' =========================
package "Plugins - Input" {

    class CsvReader <<Plugin>> {
        + read(filepath: str)
    }

    class JsonReader <<Plugin>> {
        + read(filepath: str)
    }
}

' =========================
' Output Plugins
' =========================
package "Plugins - Output" {

    class ConsoleWriter <<Plugin>> {
        + write(records, config)
        - _write_dict()
        - _write_list()
    }

    class GraphicsChartWriter <<Plugin>> {
        - save_path
        - app: DashboardApp
        + write(records, config)
        - _create_dashboard()
    }

    class DashboardApp <<VisualizationEngine>> {
        - pages
        - current_page_idx
        - fig
        + add_new_page(title)
        + add_element(page, func)
        + run()
    }
}

' =========================
' Relationships
' =========================

DataSource <|.. CsvReader
DataSource <|.. JsonReader

DataSink <|.. ConsoleWriter
DataSink <|.. GraphicsChartWriter

Engine o-- DataSink : injected
Engine ..> DataSource : uses

Main ..> Engine : instantiates
Main ..> DataSource : loads via config
Main ..> DataSink : loads via config

GraphicsChartWriter *-- DashboardApp

' =========================
' Legend
' =========================
legend right
  <<EntryPoint>> Application bootstrap
  <<Core>> Business logic layer
  <<PipelineService>> Core pipeline interface
  <<Plugin>> Extensible implementation
  <<VisualizationEngine>> UI rendering engine
end legend

@enduml